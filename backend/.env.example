# =============================================================
# SwarLipi AI Backend — Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values

# --- Application ---
APP_NAME=SwarLipi AI
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=your-secret-key-change-this-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://swarlipi:swarlipi_pass@localhost:5432/swarlipi_db
DATABASE_URL_SYNC=postgresql://swarlipi:swarlipi_pass@localhost:5432/swarlipi_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Google Cloud Storage ---
GCS_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_RAW=swarlipi-raw-uploads
GCS_BUCKET_STEMS=swarlipi-separated-stems
GCS_BUCKET_SCORES=swarlipi-generated-scores
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# --- AI Models ---
MT3_MODEL_PATH=./models/mt3
DEMUCS_MODEL=htdemucs_ft

# --- Auth ---
JWT_SECRET_KEY=your-jwt-secret-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- File Upload ---
MAX_UPLOAD_SIZE_MB=100
MAX_AUDIO_DURATION_SECONDS=600
UPLOAD_DIR=./uploads

# --- Gemini API ---
GEMINI_API_KEY=your-gemini-api-key
